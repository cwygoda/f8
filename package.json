{
  "name": "@cwygoda/f8",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Image-first publishing toolkit for SvelteKit.",
  "license": "MIT",
  "packageManager": "pnpm@11.0.4",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "bin": {
    "f8": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline/index.d.ts",
      "default": "./dist/pipeline/index.js"
    },
    "./markdown": {
      "types": "./dist/markdown/index.d.ts",
      "default": "./dist/markdown/index.js"
    },
    "./sveltekit": {
      "types": "./dist/sveltekit/index.d.ts",
      "default": "./dist/sveltekit/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "default": "./dist/svelte/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "rm -rf dist build && svelte-kit sync && vite build && svelte-package && tsup src/cli/index.ts --format esm --dts --out-dir dist/cli --clean false",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "quality": "pnpm lint && pnpm check && pnpm test && pnpm build",
    "test:watch": "vitest",
    "f8": "tsx src/cli/index.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0.9",
    "@sveltejs/kit": "^2.27.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "blurhash": "^2.0.5",
    "exifr": "^7.1.3",
    "mdsvex": "^0.12.7",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.34.5",
    "smol-toml": "^1.4.2",
    "svelte": "^5.38.10",
    "unified": "^11.0.5",
    "yaml": "^2.9.0",
    "zod": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@go-task/cli",
      "esbuild",
      "sharp"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.34.0",
    "@go-task/cli": "^3.51.1",
    "@sveltejs/package": "^2.4.1",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.3.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.11.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte-check": "^4.3.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.41.0",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
