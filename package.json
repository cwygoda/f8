{
  "name": "@cwygoda/f8",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "description": "Image-first publishing toolkit for SvelteKit.",
  "license": "MIT",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "bin": {
    "f8": "./dist/cli/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./pipeline": {
      "types": "./dist/pipeline/index.d.ts",
      "default": "./dist/pipeline/index.js"
    },
    "./markdown": {
      "types": "./dist/markdown/index.d.ts",
      "default": "./dist/markdown/index.js"
    },
    "./sveltekit": {
      "types": "./dist/sveltekit/index.d.ts",
      "default": "./dist/sveltekit/index.js"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.ts",
      "svelte": "./dist/svelte/index.js",
      "default": "./dist/svelte/index.js"
    },
    "./components/F8Image.svelte": {
      "types": "./dist/components/F8Image.svelte.d.ts",
      "svelte": "./dist/components/F8Image.svelte",
      "default": "./dist/components/F8Image.svelte"
    },
    "./components/F8Gallery.svelte": {
      "types": "./dist/components/F8Gallery.svelte.d.ts",
      "svelte": "./dist/components/F8Gallery.svelte",
      "default": "./dist/components/F8Gallery.svelte"
    },
    "./components/F8Viewer.svelte": {
      "types": "./dist/components/F8Viewer.svelte.d.ts",
      "svelte": "./dist/components/F8Viewer.svelte",
      "default": "./dist/components/F8Viewer.svelte"
    },
    "./components/image-utils": {
      "types": "./dist/components/image-utils.d.ts",
      "default": "./dist/components/image-utils.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "rm -rf dist build && svelte-kit sync && vite build && svelte-package && tsup src/cli/index.ts --format esm --dts --out-dir dist/cli --clean false",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium webkit",
    "quality": "pnpm lint && pnpm check && pnpm test && pnpm build",
    "test:watch": "vitest",
    "preview": "vite preview",
    "release:dry-run": "tsx scripts/release.ts --dry-run",
    "release": "tsx scripts/release.ts",
    "changelog": "tsx scripts/release.ts --changelog-only",
    "pack:check": "pnpm build && pnpm pack --dry-run",
    "consumer:check": "tsx scripts/verify-package-consumer.ts",
    "f8": "tsx src/cli/index.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.65.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "blurhash": "^2.0.5",
    "exifr": "^7.1.3",
    "mdsvex": "^0.12.7",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.35.1",
    "smol-toml": "^1.6.1",
    "svelte": "^5.56.3",
    "unified": "^11.0.5",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "maplibre-gl": "^5.24.0"
  },
  "peerDependenciesMeta": {
    "maplibre-gl": {
      "optional": true
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@go-task/cli": "^3.51.1",
    "@playwright/test": "^1.60.0",
    "@sveltejs/package": "^2.5.8",
    "@types/geojson": "^7946.0.16",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.3",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.0",
    "svelte-check": "^4.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
